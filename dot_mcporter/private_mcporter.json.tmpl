{
  "mcpServers": {
    "analytics-mcp": {
      "command": "pipx",
      "args": [
        "run",
        "analytics-mcp"
      ],
      "env": {
        "GOOGLE_APPLICATION_CREDENTIALS": "{{ .chezmoi.homeDir }}/.config/gcloud/application_default_credentials.json",
        "GOOGLE_PROJECT_ID": "analytics-mcp-492303"
      }
    },
    "aws-mcp": {
      "command": "uvx",
      "args": [
        "mcp-proxy-for-aws@latest",
        "https://aws-mcp.us-east-1.api.aws/mcp",
        "--metadata",
        "AWS_REGION=ap-northeast-1"
      ]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "chrome-devtools-mcp@latest"
      ]
    },
    "drawio": {
      "command": "npx",
      "args": [
        "@drawio/mcp"
      ]
    },
    "exa": {
      "url": "https://mcp.exa.ai/mcp"
    },
    "home-assistant": {
      "command": "uvx",
      "args": [
        "ha-mcp@latest"
      ],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR",
        "HOMEASSISTANT_URL": "{{ onepasswordRead "op://chezmoi/Home Assistant - MCP Server/url" }}",
        "HOMEASSISTANT_TOKEN": "{{ onepasswordRead "op://chezmoi/Home Assistant - MCP Server/credential" }}"
      }
    },
    "ticktick": {
      "url": "https://mcp.ticktick.com",
      "oauthScopes": []
    },
    "unifi-network": {
      "command": "uvx",
      "args": ["unifi-network-mcp@latest"],
      "env": {
        "UNIFI_NETWORK_HOST": "{{ onepasswordRead "op://chezmoi/unifi-mcp/hostname" }}",
        "UNIFI_NETWORK_USERNAME": "{{ onepasswordRead "op://chezmoi/unifi-mcp/username" }}",
        "UNIFI_NETWORK_PASSWORD": "{{ onepasswordRead "op://chezmoi/unifi-mcp/credential" }}"
      }
    },
    "zabbix": {
      "url": "http://fox.rewse.jp:8080/mcp",
      "headers": {
        "Authorization": "Bearer {{ onepasswordRead "op://chezmoi/Zabbix MCP Server/credential" }}"
      }
{{- if eq .chezmoi.hostname "7cf34ded5d65" }}
    },
    "amazon-quick-mcp": {
      "command": "amazon-quick-mcp",
      "env": {
        "QUICKSIGHT_ACCOUNT": "amazonbi",
        "QUICKSIGHT_REGION": "us-east-1"
      }
    },
    "amazon-sharepoint-mcp": {
      "command": "amazon-sharepoint-mcp"
    },
    "atoz-mcp" : {
      "command" : "atoz-mcp",
    },
    "aws-gitlab-mcp" : {
      "command" : "aws-gitlab-mcp"
    },
    "aws-insights-mcp": {
      "command": "aws-insights-mcp"
    },
    "aws-outlook-mcp": {
      "command": "aws-outlook-mcp",
      "env": {
        "OUTLOOK_MCP_ENABLE_WRITES": "true"
      }
    },
    "aws-sentral-mcp": {
      "command": "aws-sentral-mcp"
    },
    "builder-mcp": {
      "command": "builder-mcp"
    },
    "concur-mcp": {
      "command": "concur-mcp"
    },
    "hs-kmine-mcp" : {
      "command" : "hs-kmine-mcp"
    },
    "loop-mcp" : {
      "command" : "loop-mcp"
    },
    "pippin-mcp" : {
      "command" : "pippin-mcp-server"
    },
    "slack-mcp": {
      "command": "slack-mcp"
    },
    "spec-req-mcp": {
      "command": "spec-req-mcp"
    },
    "specialist-super-agent-mcp": {
      "command": "specialist-super-agent-mcp"
{{- end }}
    }
  }
}

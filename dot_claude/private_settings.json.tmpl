{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_USE_BEDROCK": "1",
    "CLAUDE_CODE_ENABLE_AUTO_MODE": "1",
{{- if ne .chezmoi.hostname "7cf34ded5d65" }}
    "AWS_PROFILE": "bedrock",
{{- end }}
    "AWS_REGION": "us-west-2"
  },
{{ if eq .chezmoi.hostname "7cf34ded5d65" }}
  "awsCredentialExport": "\"{{ .chezmoi.homeDir }}/.toolbox/bin/claude\" default-credential-export",
  "enabledPlugins": {
    "AmazonBuilderCoreAIAgents-core@aim": true,
    "AmazonBuilderCoreAIAgents-pipeline-assistant@aim": true
  },
  "extraKnownMarketplaces": {
    "aim": {
      "source": {
        "source": "directory",
        "path": "{{ .chezmoi.homeDir }}/.aim/cc-plugins"
      }
    }
  },
  "availableModels": [
    "claude-fable-5",
    "claude-opus-4-6[1m]",
    "claude-opus-4-6",
    "claude-opus-4-7[1m]",
    "claude-opus-4-7",
    "claude-opus-4-8[1m]",
    "claude-opus-4-8",
    "claude-sonnet-4-6",
    "claude-sonnet-4-6[1m]",
    "claude-sonnet-5",
    "claude-haiku-4-5"
  ],
{{- else }}
  "availableModels": [
    "haiku",
    "opus",
    "sonnet"
  ],
{{- end }}
  "hooks": {
{{- if eq .chezmoi.os "darwin" }}
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "OTTY_CLI='/Applications/Otty.app/Contents/MacOS/otty-cli' '/Applications/Otty.app/Contents/Resources/agent-integration/claude/otty-hook.sh' awaiting \"$PPID\" ctx"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "OTTY_CLI='/Applications/Otty.app/Contents/MacOS/otty-cli' '/Applications/Otty.app/Contents/Resources/agent-integration/claude/otty-hook.sh' processing \"$PPID\""
          }
        ]
      }
    ],
{{- end }}
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.agents/hooks/block-compound-command.sh"
          },
          {
            "type": "command",
            "command": "{{ .chezmoi.homeDir }}/.agents/hooks/enforce-uv.sh"
          }
        ]
      }{{ if eq .chezmoi.os "darwin" }},
      {
        "hooks": [
          {
            "type": "command",
            "command": "OTTY_CLI='/Applications/Otty.app/Contents/MacOS/otty-cli' '/Applications/Otty.app/Contents/Resources/agent-integration/claude/otty-hook.sh' processing \"$PPID\""
          }
        ]
      }{{ end }}
    ]{{ if eq .chezmoi.os "darwin" }},
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "OTTY_CLI='/Applications/Otty.app/Contents/MacOS/otty-cli' '/Applications/Otty.app/Contents/Resources/agent-integration/claude/otty-hook.sh' idle \"$PPID\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "OTTY_CLI='/Applications/Otty.app/Contents/MacOS/otty-cli' '/Applications/Otty.app/Contents/Resources/agent-integration/claude/otty-hook.sh' idle \"$PPID\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "OTTY_CLI='/Applications/Otty.app/Contents/MacOS/otty-cli' '/Applications/Otty.app/Contents/Resources/agent-integration/claude/otty-hook.sh' processing \"$PPID\""
          }
        ]
      }
    ]{{ end }}
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "defaultMode": "auto",
    "additionalDirectories": [
      "/tmp",
      "{{ .chezmoi.homeDir }}/Desktop",
      "{{ .chezmoi.homeDir }}/Downloads"
    ]
  },
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "~/.claude/statusline.sh",
    "type": "command"
  },
  "theme": "auto",
{{- if eq .chezmoi.hostname "7cf34ded5d65" }}
  "model": "global.anthropic.claude-opus-4-8[1m]",
  "modelOverrides": {
    "claude-fable-5": "global.anthropic.claude-fable-5[1m]",
    "claude-haiku-4-5": "global.anthropic.claude-haiku-4-5-20251001-v1:0",
    "claude-opus-4-6": "global.anthropic.claude-opus-4-6-v1",
    "claude-opus-4-6[1m]": "global.anthropic.claude-opus-4-6-v1[1m]",
    "claude-opus-4-7": "global.anthropic.claude-opus-4-7",
    "claude-opus-4-7[1m]": "global.anthropic.claude-opus-4-7[1m]",
    "claude-opus-4-8": "global.anthropic.claude-opus-4-8",
    "claude-opus-4-8[1m]": "global.anthropic.claude-opus-4-8[1m]",
    "claude-sonnet-4-6": "global.anthropic.claude-sonnet-4-6",
    "claude-sonnet-4-6[1m]": "global.anthropic.claude-sonnet-4-6[1m]",
    "claude-sonnet-5": "global.anthropic.claude-sonnet-5"
  },
  "enforceAvailableModels": true,
  "fallbackModel": [
    "global.anthropic.claude-opus-4-6-v1[1m]"
  ]
{{- end }}
}

# Anthropic Skills (https://github.com/anthropics/skills)
{{- range $anthropicSkills }}
skills/{{ . }}:
  type: archive
  url: https://github.com/anthropics/skills/archive/refs/heads/main.tar.gz
  stripComponents: 3
  include:
    - "*/skills/{{ . }}/**"
  exact: true
  refreshPeriod: 168h
{{ end }}


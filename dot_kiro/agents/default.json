{
  "name": "default",
  "description": "",
  "prompt": null,
  "mcpServers": {},
  "tools": ["*"],
  "toolAliases": {},
  "allowedTools": [
    "@builtin/delegate",
    "@builtin/glob",
    "@builtin/grep",
    "@builtin/knowledge",
    "@builtin/read",
    "@builtin/subagent",
    "@builtin/web_fetch",
    "@builtin/web_search",
    "@ticktick"
  ],
  "resources": [
    "file://AGENTS.md",
